VITE_GROQ_API_KEY=your_groq_api_key_here

# Ejecución de código — elige UNA opción:

# Opción A — JDoodle (gratis, 200 calls/día, recomendado para producción)
# Regístrate en https://jdoodle.com → API
# En Cloudflare: añade JDOODLE_CLIENT_ID y JDOODLE_CLIENT_SECRET (sin VITE_)
# En local: añade las mismas variables aquí
JDOODLE_CLIENT_ID=your_client_id_here
JDOODLE_CLIENT_SECRET=your_client_secret_here

# Opción B — Self-hosted Piston con Docker (sin límites, solo local)
# VITE_PISTON_URL=http://localhost:2000/api/v2

# Opción C — Judge0 vía RapidAPI (de pago)
# VITE_JUDGE0_KEY=your_rapidapi_key_here
